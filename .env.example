APP_NAME=rl-trade
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=console

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=5173
API_AUTH_MODE=disabled
API_AUTH_TOKEN=
API_AUTH_SUBJECT=operator

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rl_trade
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
WORKER_QUEUES=ingestion,preprocessing,supervised_training,rl_training,evaluation,trading,maintenance
WORKER_CONCURRENCY=1
WORKER_PREFETCH_MULTIPLIER=1
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=60
SCHEDULER_MAX_INTERVAL_SECONDS=10

MT5_TERMINAL_PATH=/opt/metatrader5/terminal64.exe
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

PAPER_TRADING_ONLY=true
ALLOW_LIVE_TRADING=false
MODEL_APPROVAL_MIN_CONFIDENCE=70
MODEL_APPROVAL_MIN_RISK_REWARD=2.0
