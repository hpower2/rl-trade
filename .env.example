APP_NAME=rl-trade
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=console

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=5173
FRONTEND_HOST_PORT=4173
API_AUTH_MODE=disabled
API_AUTH_TOKEN=
API_AUTH_SUBJECT=operator

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rl_trade
REDIS_URL=redis://localhost:6379/0
POSTGRES_DB=rl_trade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CPU_WORKER_QUEUES=ingestion,preprocessing,evaluation,trading,maintenance
CPU_WORKER_CONCURRENCY=1
CPU_WORKER_PREFETCH_MULTIPLIER=1
TRAINING_WORKER_QUEUES=supervised_training,rl_training
TRAINING_WORKER_CONCURRENCY=1
TRAINING_WORKER_PREFETCH_MULTIPLIER=1
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=60
SCHEDULER_MAX_INTERVAL_SECONDS=10
ARTIFACTS_ROOT_DIR=.artifacts

MT5_TERMINAL_PATH=/opt/metatrader5/terminal64.exe
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
TRAINING_WORKER_REQUIRE_CUDA=false
TRAINING_WORKER_NVIDIA_VISIBLE_DEVICES=void
TRAINING_WORKER_GPUS=all

PAPER_TRADING_ONLY=true
ALLOW_LIVE_TRADING=false
MODEL_APPROVAL_MIN_CONFIDENCE=70
MODEL_APPROVAL_MIN_RISK_REWARD=2.0
MODEL_APPROVAL_MIN_SAMPLE_SIZE=100
MODEL_APPROVAL_MAX_DRAWDOWN=20.0
